# keepup — local development backing services.
#
# Copy to `.env` (gitignored) and adjust if a port collides:
#   cp .env.example .env
#
# These are LOCAL DEVELOPMENT DEFAULTS ONLY.
# This repository is public. Never put a real credential in this file, and never
# reuse these values anywhere that is reachable from the internet. Staging and
# production secrets are supplied by the deployment environment, not from here.

# --- Network exposure -------------------------------------------------------
# Interface the published ports bind to. 127.0.0.1 keeps every service reachable
# only from this machine (localhost works as normal). Set to 0.0.0.0 ONLY when
# you deliberately want to expose the stack to your LAN — these services have
# weak dev credentials and the Mailpit UI has none.
BIND_ADDR=127.0.0.1

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=keepup
POSTGRES_USER=keepup
POSTGRES_PASSWORD=keepup
POSTGRES_PORT=5432

# --- RabbitMQ ---------------------------------------------------------------
# Not `guest`: that account is loopback-only and cannot sign into the
# management UI through a published port. See compose.dev.yml.
RABBITMQ_USER=keepup
RABBITMQ_PASSWORD=keepup
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# --- Mailpit ----------------------------------------------------------------
# Local SMTP sink. Captures every mail the app sends and delivers none of them.
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Application ------------------------------------------------------------
# Host port the `app` service publishes (container always listens on 8080).
# Not a secret; override if 8080 collides with something on your machine.
APP_PORT=8080
